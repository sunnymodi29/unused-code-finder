{
  "name": "scan-unused-code",
  "displayName": "Code Cleaner - Scan Unused Code",
  "description": "Detect, highlight, and remove unused code (dead code) in JavaScript and TypeScript projects.",
  "version": "1.0.5",
  "publisher": "sunnymodi",
  "license": "MIT",
  "icon": "resources/icon.png",

  "engines": {
    "vscode": "^1.116.0"
  },

  "categories": ["Linters"],

  "keywords": [
    "unused",
    "unused code",
    "dead code",
    "code cleaner",
    "clean code",
    "remove unused",
    "code cleanup",
    "typescript unused",
    "javascript unused",
    "code scan",
    "detect unused",
    "remove dead code"
  ],

  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],

  "main": "./out/extension.js",

  "homepage": "https://github.com/sunnymodi29/unused-code-finder",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunnymodi29/unused-code-finder.git"
  },
  "bugs": {
    "url": "https://github.com/sunnymodi29/unused-code-finder/issues"
  },

  "contributes": {
    "commands": [
      {
        "command": "unused.deleteFromSidebar",
        "title": "Delete"
      }
    ],

    "viewsContainers": {
      "activitybar": [
        {
          "id": "unused-sidebar",
          "title": "Code Cleaner",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    },

    "views": {
      "unused-sidebar": [
        {
          "type": "webview",
          "id": "unusedSidebar",
          "name": "Scan Unused Code",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    },

    "menus": {
      "view/item/context": [
        {
          "command": "unused.deleteFromSidebar",
          "when": "view == unusedSidebar && viewItem == unusedItem",
          "group": "inline"
        }
      ]
    }
  },

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "vscode-test"
  },

  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },

  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0"
  }
}