{
  "name": "scan-unused-code",
  "displayName": "Scan Unused Code",
  "description": "Detect and remove unused code in JavaScript and TypeScript projects directly from VS Code.",
  "version": "1.0.3",
  "publisher": "sunnymodi",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "unused code",
    "code cleanup",
    "javascript",
    "typescript",
    "remove unused",
    "vscode extension",
    "code quality"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./out/extension.js",

  "homepage": "https://github.com/sunnymodi29/unused-code-finder",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunnymodi29/unused-code-finder.git"
  },
  "bugs": {
    "url": "https://github.com/sunnymodi29/unused-code-finder/issues"
  },

  "contributes": {
    "commands": [
      {
        "command": "unused.removeCurrent",
        "title": "Remove Unused Line"
      },
      {
        "command": "unused.removeAll",
        "title": "Remove All Unused Code"
      },
      {
        "command": "unused.refresh",
        "title": "Refresh Unused List"
      },
      {
        "command": "unused.deleteFromSidebar",
        "title": "Delete Unused"
      },
      {
        "command": "unused.removeAllFromSidebar",
        "title": "Remove All",
        "when": "view == unusedSidebar",
        "group": "navigation"
      }
    ],

    "viewsContainers": {
      "activitybar": [
        {
          "id": "unused-sidebar",
          "title": "Unused Code",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    },

    "views": {
      "unused-sidebar": [
        {
          "id": "unusedSidebar",
          "name": "Unused Items"
        }
      ]
    },

    "menus": {
      "view/title": [
        {
          "command": "unused.removeAllFromSidebar",
          "when": "view == unusedSidebar",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "unused.deleteFromSidebar",
          "when": "view == unusedSidebar && viewItem == unusedItem",
          "group": "inline"
        }
      ]
    }
  },

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },

  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },

  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0"
  }
}